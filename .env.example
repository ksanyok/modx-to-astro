# ═══════════════════════════════════════════════════════════════
# Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your site.
#
#   cp .env.example .env
#
# These values are used by:
#   - Makefile (make migrate / make deploy)
#   - scripts/deploy.sh
#   - .gitlab-ci.yml (can override via CI/CD Variables)
# ═══════════════════════════════════════════════════════════════

# ── Site Data ───────────────────────────────────────────────
# Path to the SQL dump (relative to project root)
SQL_PATH=data/dump.sql

# Path to the MODX assets directory (relative to project root)
ASSETS_PATH=data/assets

# ── Site Identity ───────────────────────────────────────────
# Production domain (used for sitemap, canonical URLs)
SITE_DOMAIN=example.ch

# ── Deployment ──────────────────────────────────────────────
# SSH user@host for rsync deploy
DEPLOY_HOST=user@server.example.com

# Remote path to the website document root (Plesk: /var/www/vhosts/domain/httpdocs)
# After first deploy this path becomes a symlink pointing to the current release.
DEPLOY_PATH=/var/www/vhosts/example.ch/httpdocs

# SSH port (default: 22; change if your host uses a non-standard port)
DEPLOY_PORT=22

# How many timestamped releases to keep on the server for rollback
# Increase for more rollback history, decrease to save disk space.
KEEP_RELEASES=3

# URL checked with HTTP GET after every deploy (must return 200)
# Leave blank to skip the health check.
HEALTH_URL=https://example.ch
